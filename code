import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load the data
df = pd.read_csv('/content/data.csv')
print("Original DataFrame head:")
print(df.head())
print("\nOriginal DataFrame description:")
print(df.describe())

# Data Cleaning (from cell fHCervIC9A7u)
df.dropna(inplace=True)
df.columns = df.columns.str.lower()

# Number of products sold by product type (from cell WJZdXjoF9N5n)
print("\nNumber of products sold by product type:")
plt.figure(figsize=(8, 5))
df.groupby('product type')['number of products sold'].sum().plot(kind='bar')
plt.title('Number of Products Sold by Product Type')
plt.xlabel('Product Type')
plt.ylabel('Number of Products Sold')
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()

# Revenue Generated by Product Type (from cell 80a7bcf3)
print("\nRevenue Generated by Product Type:")
plt.figure(figsize=(10, 6))
df.groupby('product type')['revenue generated'].sum().sort_values(ascending=False).plot(kind='bar', color='skyblue')
plt.title('Total Revenue Generated by Product Type')
plt.xlabel('Product Type')
plt.ylabel('Total Revenue Generated')
plt.xticks(rotation=45)
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.tight_layout()
plt.show()

# Revenue Generated by Location (from cell 32d4d884)
print("\nRevenue Generated by Location:")
plt.figure(figsize=(12, 6))
df.groupby('location')['revenue generated'].sum().sort_values(ascending=False).plot(kind='bar', color='lightcoral')
plt.title('Total Revenue Generated by Location')
plt.xlabel('Location')
plt.ylabel('Total Revenue Generated')
plt.xticks(rotation=45)
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.tight_layout()
plt.show()

# Price Distribution (from cell f8d7fbeb)
print("\nPrice Distribution:")
plt.figure(figsize=(8, 5))
sns.histplot(df['price'], bins=20, kde=True, color='lightgreen')
plt.title('Distribution of Product Prices')
plt.xlabel('Price')
plt.ylabel('Frequency')
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.tight_layout()
plt.show()vvvvvvvvvvvvvvvvv
